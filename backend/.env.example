# Server
PORT=9099

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/strive_blog

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@striveblog.com

# Nodemailer (dev / ethereal)
HOST=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:9099/auth/google/callback

# Frontend (CORS / OAuth redirect)
FRONTEND_URL=http://localhost:5173
